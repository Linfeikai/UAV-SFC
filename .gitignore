
multirun/         # Hydra 多次运行的结果文件夹
results/          # 训练结果文件夹（如果不想提交训练结果）
experiments/       

# 2. 忽略特定文件类型（可选补充）
*.log            # 所有 .log 后缀的日志文件
*.tmp            # 所有 .tmp 临时文件
.DS_Store        # Mac 系统自动生成的文件
Thumbs.db        # Windows 系统自动生成的文件


# --- 实验结果与日志 (重点) ---
**/experiments/
**/tb_logs/        # TensorBoard 日志
**/results/
**/logs/
*.tfevents.* # 所有的 TensorBoard 事件文件

# --- 模型权重与数据 ---
*.pth              # PyTorch 模型
*.pt               # PyTorch 模型
*.pkl              # 序列化对象 (常见于 RL 的 Replay Buffer)
*.onnx             # 导出模型
*.h5               # Keras/H5py 数据
*.npy              # Numpy 数组数据
*.npz              # Numpy 压缩数据

# --- Python 环境与缓存 ---
__pycache__/
*.py[cod]
*$py.class
.venv/
env/
venv/
ENV/

# --- 操作系统与 IDE ---
.DS_Store
Thumbs.db
.vscode/           # 如果你不想分享你的 VS Code 配置
.idea/             # PyCharm 配置
*.swp
*.bak

# --- 编译与打包 ---
build/
dist/
*.egg-info/